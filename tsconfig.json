{
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2017",
    "module": "none",
    "outFile": "dist/game.js",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "sourceMap": true,
    "lib": ["DOM", "ES2017"]
