  "files": [
    "src/types/phaser-global.d.ts",
    "src/types/game_types.ts",
    "src/game_definitions.ts",
    "src/physics_ragdoll.ts",
    "src/physics_level.ts",
    "src/menu.ts",
    "src/level_1.ts",
    "src/level_2.ts",
    "src/level_3.ts",
    "src/level_timed.ts",
    "src/pause_menu.ts",
    "src/summary_menu.ts",
    "src/main_menu.ts",
    "src/physics_game.ts"
  ]
}
